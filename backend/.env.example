# Copy this file to .env and fill in values before running the app.
# The app runs without any of these set — they are all optional overrides.

# Host and port for uvicorn (defaults: 127.0.0.1 / 8000)
HOST=127.0.0.1
PORT=8000

# Absolute path to the trained pipeline file.
# Defaults to: <project-root>/backend/models/pipeline.pkl
# PIPELINE_PATH=/path/to/pipeline.pkl
